    "tailwindcss": "^4.2.1",
    "vue": "^3.5.29",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.2",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^22.18.11",
    "@types/yauzl": "^3.4.0",
    "@vitejs/plugin-vue": "^6.0.1",
